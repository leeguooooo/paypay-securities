# Default account: copy to ~/.paypay-sec/.env and fill in. NEVER commit it.
# Additional accounts: copy to ~/.paypay-sec/<name>.env, then use `paypay <cmd> -a <name>`.
PAYPAY_MEMBER_ID=Pxxxxxxxxx
PAYPAY_PASSWORD=your-password

# Full Cookie header string copied from a logged-in browser session.
# MUST contain the trusted-device token (..._SMS_AUTH_STRING=...) so login
# skips SMS. Without it the server may set IF_NEED_SMS_FLG=1 and login fails.
PAYPAY_COOKIE=102888657_SMS_AUTH_STRING=...; _ga=...

# Optional; matches the captured web login. Default: uuid_pc
PAYPAY_UUID=uuid_pc
